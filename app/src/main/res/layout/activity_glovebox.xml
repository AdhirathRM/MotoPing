<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oled_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:background="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIGITAL GLOVEBOX"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECURE DOCUMENT STORAGE"
                    android:textColor="#7A7A7A"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCUMENT 1 (RC)"
            android:textColor="#7A7A7A"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpload1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD DOCUMENT 1"
            android:textColor="@color/white"
            android:backgroundTint="#242424"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/cardDoc1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#161616"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#00E676" />
            <TextView android:id="@+id/textDoc1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Document_1.pdf" android:textColor="@color/white" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <ImageButton android:id="@+id/btnDelete1" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#FF1744" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCUMENT 2 (INSURANCE)"
            android:textColor="#7A7A7A"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpload2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD DOCUMENT 2"
            android:textColor="@color/white"
            android:backgroundTint="#242424"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/cardDoc2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#161616"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#00E676" />
            <TextView android:id="@+id/textDoc2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Document_2.pdf" android:textColor="@color/white" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <ImageButton android:id="@+id/btnDelete2" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#FF1744" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCUMENT 3"
            android:textColor="#7A7A7A"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpload3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD DOCUMENT 3"
            android:textColor="@color/white"
            android:backgroundTint="#242424"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/cardDoc3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#161616"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#00E676" />
            <TextView android:id="@+id/textDoc3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Document_3.pdf" android:textColor="@color/white" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <ImageButton android:id="@+id/btnDelete3" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#FF1744" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCUMENT 4"
            android:textColor="#7A7A7A"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpload4"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD DOCUMENT 4"
            android:textColor="@color/white"
            android:backgroundTint="#242424"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/cardDoc4"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#161616"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#00E676" />
            <TextView android:id="@+id/textDoc4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Document_4.pdf" android:textColor="@color/white" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <ImageButton android:id="@+id/btnDelete4" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#FF1744" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOCUMENT 5"
            android:textColor="#7A7A7A"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUpload5"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD DOCUMENT 5"
            android:textColor="@color/white"
            android:backgroundTint="#242424"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:id="@+id/cardDoc5"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#161616"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" android:tint="#00E676" />
            <TextView android:id="@+id/textDoc5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Document_5.pdf" android:textColor="@color/white" android:textSize="16sp" android:fontFamily="sans-serif-black" />
            <ImageButton android:id="@+id/btnDelete5" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#FF1744" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>